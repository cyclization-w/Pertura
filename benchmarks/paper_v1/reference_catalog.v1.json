{
  "schema_version": "pertura-paper-reference-catalog-v1",
  "benchmark_name": "Pertura independent scientific references",
  "principles": [
    "A runner completion status is never a scientific reference.",
    "A Pertura-produced scalar is never used as its own reference.",
    "Each capability has exactly one primary reference pack, although a pack may contain real, planted, protocol, and refusal evidence.",
    "Reference generators may read frozen datasets, split identities, and external method implementations, but not the Pertura result being scored.",
