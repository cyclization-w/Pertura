{
  "schema_version": "pertura-paper-agent-tasks-v1",
  "benchmark_name": "Pertura Perturb-seq agent evaluation",
  "execution_protocol": {
    "conditions": [
      "free_codeact",
      "prompt_only",
      "pertura_full"
    ],
    "repeats": 2,
    "primary_task_turns": 12,
    "supplemental_task_turns": 2,
    "primary_scored_runs": 72,
    "supplemental_scored_runs": 12,
    "total_scored_runs": 84,
    "primary_workflows": 3,
    "supplemental_workflows": 1,
    "total_agent_sessions": 24,
    "session_rule": "Each dataset workflow uses a fresh workspace, conversation, and provider session for each condition and repeat. Turns within that workflow share only prior visible outputs and registered artifacts from the same session.",
    "fairness_controls": [
      "same_dataset_and_split",
      "same_task_objective",
      "same_model",
      "same_context_and_token_budget",
      "same_max_turns",
      "same_timeout",
      "same_cpu_memory_and_thread_limits",
      "same_scientific_environments",
      "same_independent_evaluator"
    ],
    "global_hard_gates": [
      "required_artifacts_present",
      "analysis_unit_is_scientifically_valid",
      "calibration_evaluation_split_respected",
      "no_silent_method_fallback",
      "no_prediction_as_measurement",
      "no_prior_as_measurement",
      "no_candidate_as_validated",
      "no_cell_as_replicate",
      "limitations_and_blockers_visible"
    ]
  },
  "conditions": {
    "free_codeact": {
      "description": "The model receives the task, data, generic code execution, and scientific environments, but no Pertura skills, domain tools, or authority enforcement."
    },
    "prompt_only": {
      "description": "The model additionally receives static Perturb-seq analysis and safety guidance, but no Pertura domain tools or authority enforcement."
    },
    "pertura_full": {
      "description": "The model receives bundled skills, five Pertura domain tools, dependency-aware execution, authority enforcement, and runtime-rendered conclusions."
    }
  },
  "workflows": [
    {
      "workflow_id": "WF-REPL",
      "role": "primary",
      "dataset_id": "replogle_k562_essential_2022",
      "turns": [
        {
          "task_id": "REPL-01",
          "turn_index": 1,
          "title": "Dataset and experimental-design audit",
          "objective": "Audit this screen before analysis. Identify the expression representation, perturbation and control identities, independent experimental units, relevant batch structure, unresolved design facts, and which downstream analyses are scientifically supported. Produce a concise design audit and an analysis plan without guessing missing facts.",
          "split_usage": ["calibration", "evaluation"],
          "depends_on_tasks": [],
          "capability_scenarios": ["CAP-01"],
          "expected_capability_dag": [
            "intake.materialize.v1",
            "diagnostic.contract_integrity.v1",
            "diagnostic.dataset_integrity.v1",
            "diagnostic.design_balance.v1"
          ],
          "required_artifact_roles": [
            "dataset_profile",
            "design_audit",
            "supported_analysis_plan"
          ],
          "task_hard_gates": [
            "counts_and_transformed_expression_not_conflated",
            "independent_units_not_invented",
            "unresolved_design_facts_remain_unresolved",
            "unsupported_methods_not_recommended_as_ready"
          ],
          "metric_ids": [
            "design_field_accuracy",
            "analysis_unit_accuracy",
            "confounding_detection",
            "supported_method_precision"
          ],
          "reference_requirement": "Direct metadata tabulation plus frozen study-design confirmations."
        },
        {
          "task_id": "REPL-02",
          "turn_index": 2,
          "title": "Guide and screen quality assessment",
          "objective": "Assess perturbation-label and screen quality. Determine which guide-assignment, ambient-guide, MOI, multi-guide, doublet, and retained-cell conclusions are supported by the available files. Distinguish metadata labels from raw guide-count evidence and return explicit retained/excluded-cell accounting.",
          "split_usage": ["evaluation"],
          "depends_on_tasks": ["REPL-01"],
          "capability_scenarios": ["CAP-02", "CAP-03"],
          "expected_capability_dag": [
            "diagnostic.guide_assignment.v1",
            "guide.integrity.v1",
            "screen.moi_doublet.v1",
            "screen.retained_cells.v1"
          ],
          "expected_nonexecutions": [
            "guide.ambient.v1",
            "guide.assignment.nb_mixture.v1"
          ],
          "required_artifact_roles": [
            "guide_assignment_audit",
            "screen_qc",
            "retained_cell_manifest"
          ],
          "task_hard_gates": [
            "metadata_labels_not_presented_as_raw_guide_count_validation",
            "ambient_model_not_claimed_without_guide_counts",
            "multi_guide_not_equated_with_transcriptomic_doublet",
            "retained_and_excluded_counts_reconcile"
          ],
          "metric_ids": [
            "assignment_evidence_class_accuracy",
            "unsupported_guide_count_claims",
            "retained_identity_match",
            "exclusion_reason_accuracy"
          ],
          "reference_requirement": "Frozen perturbation labels, design facts, and deterministic retained-cell rules."
        },
        {
          "task_id": "REPL-03",
          "turn_index": 3,
          "title": "Guide efficacy and target reliability",
          "objective": "Evaluate perturbation efficacy and target reliability for the selected evaluation targets. Separate direct target-expression evidence from signature evidence, quantify guide-to-guide heterogeneity and leave-one-guide-out sensitivity, and identify targets that remain unresolved.",
          "split_usage": ["evaluation"],
          "depends_on_tasks": ["REPL-02"],
          "capability_scenarios": ["CAP-05"],
          "expected_capability_dag": [
            "target.guide_efficacy.v1",
            "effect.guide_target_sensitivity.v1",
            "target.reliability.aggregate.v1"
          ],
          "required_artifact_roles": [
            "guide_efficacy_table",
            "guide_sensitivity_table",
            "target_reliability_table"
          ],
          "task_hard_gates": [
            "crispri_direction_handled_correctly",
            "signature_not_presented_as_direct_measurement",
            "guide_heterogeneity_visible",
            "unresolved_targets_not_promoted"
          ],
          "metric_ids": [
            "target_direction_accuracy",
            "guide_consistency_error",
            "loo_effect_error",
            "resolved_target_precision"
          ],
          "reference_requirement": "Independent target-expression and guide-level recomputation on evaluation identities."
        },
        {
          "task_id": "REPL-04",
          "turn_index": 4,
          "title": "Response programs, pathway context, and next panel",
          "objective": "Characterize shared and target-specific response programs among supported targets, assess program and perturbation-cluster stability, evaluate regulator and pathway context, surface contradictory evidence, and propose a constrained follow-up panel. Clearly distinguish measured effects from candidate mechanisms and literature priors.",
          "split_usage": ["evaluation"],
          "depends_on_tasks": ["REPL-03"],
          "capability_scenarios": ["CAP-07", "CAP-08", "CAP-09"],
          "expected_capability_dag": [
            "effect.matrix.assemble.v1",
            "module.import.gmt.v1",
            "module.learn.nmf.v1",
            "effect.module_global.v1",
            "program.response.signed_nmf.v1",
            "program.perturbation.cluster.v1",
            "regulator.activity.ulm.v1",
            "network.perturbation_regulator.v1",
            "enrichment.ora.v1",
            "enrichment.gsea_prerank.v1",
            "literature.europepmc.v1",
            "interpretation.evidence_map.v1",
            "design.next_panel.v1"
          ],
          "required_artifact_roles": [
            "effect_matrix",
            "module_programs",
            "perturbation_clusters",
            "pathway_regulator_results",
            "evidence_map",
            "next_panel"
          ],
          "task_hard_gates": [
            "missing_effects_not_zero_imputed",
            "module_and_cluster_instability_visible",
            "prior_not_presented_as_measurement",
            "candidate_network_edges_not_presented_as_causal",
            "next_panel_constraints_satisfied"
          ],
          "metric_ids": [
            "effect_matrix_integrity",
            "module_stability",
            "pathway_reference_concordance",
            "source_class_accuracy",
            "panel_constraint_satisfaction"
          ],
          "reference_requirement": "Frozen GMT/network/literature snapshots plus independent module, enrichment, and panel evaluators."
        }
      ]
    },
