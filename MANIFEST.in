include README.md
include pyproject.toml
include MANIFEST.in
recursive-include benchmarks *.md *.json
recursive-include compatibility *.json
recursive-include scripts *.py *.R *.ps1
recursive-include ui *.html *.json *.ts *.tsx *.css
recursive-include docs *.md *.json *.yaml
recursive-include src/pertura_workflow/capabilities/specs *.yaml
include src/pertura_workflow/capabilities/planner_routes.json
recursive-include src/pertura_workflow/capabilities/profiles *.yaml
recursive-include src/pertura_workflow/capabilities/runners *.R
recursive-include src/pertura_workflow/environments *.yml *.R
recursive-include src/pertura_runtime/dashboard_static *
recursive-include src/pertura_bench/runners *.R
recursive-include src/pertura_bench/schemas *.json
recursive-include src/pertura_bench/cases *.json
recursive-include src/pertura_core/compatibility/v0.2 *.json
prune ui/node_modules
prune build
prune dist
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.h5ad
global-exclude *.h5
global-exclude *.rds
global-exclude *.rda
